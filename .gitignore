# === Whitelist mode: ignore everything by default, then re-allow only known demo files ===
*

# Re-allow this gitignore itself
!.gitignore

# Re-allow project meta
!README.md

# Re-allow demo HTML files (explicit list, not wildcard)
!index.html
!brand.html
!products.html
!academy.html
!challenge.html
!digital.html
!admin.html
!career.html
!onboarding.html
!login.html
!day3.html
!firebase-app.js
!firestore.rules
!firebase.json
!.firebaserc
!package.json
!package-lock.json
!舞光_產品資料.json
!products.json

# Re-allow assets folder and contents
!assets/
!assets/**

# Re-allow backend folder (deploys to fly.io, not GitHub Pages)
!backend/
!backend/**

# Re-allow knowledge base markdown for NotebookLM upload
!kb/
!kb/**

# Explicitly never include
research_notes.md
content/
logo_base64.txt
.DS_Store
Thumbs.db
*.tmp
*.bak

# Backend secrets / venv (絕對不能進 repo)
backend/credentials/notebooklm_storage.json
backend/credentials/*.json
backend/.venv/
backend/__pycache__/
backend/.env

# Generated system prompt (KB + persona) — 重新生成即可，不需進 git
backend/kb_full_system_prompt.txt
backend/cookie_lifetime_log*.csv
backend/test_stdout.log
